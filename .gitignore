# Ignore everything in models except .gitkeep
/models/*
!/models/.gitkeep

# Ignore all jpg images in output/frames except .gitkeep
/output/frames/*
!/output/frames/.gitkeep

# Ignore all json files in output/json_messages except .gitkeep
/output/json_messages/*
!/output/json_messages/.gitkeep

# Ignore rendered videos under output/videos (keep placeholder)
/output/videos/*
!/output/videos/.gitkeep

# Per-run bundles (frames / json / video / logs)
/output/runs/

# Ignore all videos in video_input except .gitkeep
/video_input/*
!/video_input/.gitkeep

# Ignore all log files in logs except .gitkeep
/logs/*
!/logs/.gitkeep

# Build / bytecode (do not commit)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
.env
